# Drizzle
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# OCR backend
OCR_PROVIDER="tesseract"
OCR_TESSERACT_LANG="eng"
OCR_MAX_FILE_SIZE_BYTES="6000000"
# Degrees after EXIF auto-rotate: -90 = 90° counter-clockwise (typical for portrait camera crop). Use 0 for uploads that are already upright.
OCR_ROTATE_AFTER_EXIF="-90"
